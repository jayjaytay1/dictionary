# Supabase — copy this file to `.env.local` and fill in values from your
# Supabase project dashboard: Project Settings → API.
# NEVER commit real keys. `.env.local` is gitignored.

# Your project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public key. Safe to expose to the browser (RLS protects data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
