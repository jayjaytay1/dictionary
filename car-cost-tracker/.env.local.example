# Supabase — copy this file to `.env.local` and fill in values from your
# Supabase project dashboard: Project Settings → API.
# NEVER commit real keys. `.env.local` is gitignored.

# Your project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public key. Safe to expose to the browser (RLS protects data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (Project Settings → API → service_role). SERVER-ONLY —
# never expose this. Used by the Stripe webhook to update subscription state.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe (billing / $5-a-month paywall). Leave blank to keep the app free —
# the paywall only activates once STRIPE_SECRET_KEY + STRIPE_PRICE_ID are set.
# ---------------------------------------------------------------------------
# Secret key from the Stripe dashboard (Developers → API keys).
STRIPE_SECRET_KEY=
# The recurring $5/month Price id (Products → your product → Pricing).
STRIPE_PRICE_ID=
# Webhook signing secret (Developers → Webhooks → your endpoint).
STRIPE_WEBHOOK_SECRET=

# Optional: your site's public URL, used for Stripe redirect URLs when the
# request origin isn't available (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=
